<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="900.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Cinema.Controlador.ControllerCriarConta">
    <children>

        <AnchorPane layoutX="450.0" prefHeight="500.0" prefWidth="450.0" style="-fx-background-color: #7e15d0;">
            <children>
                <Label alignment="CENTER" layoutX="40.0" layoutY="160.0" prefWidth="370.0" text="Bem-vindo ao CineStar" textAlignment="CENTER" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>
                <Label alignment="CENTER" layoutX="50.0" layoutY="220.0" prefHeight="90.0" prefWidth="350.0" text="Cadastre-se no nosso cinema e surpreenda-se com nossa qualidade e filmes incríveis." textAlignment="CENTER" textFill="WHITE" wrapText="true">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>

        <Pane prefHeight="500.0" prefWidth="450.0" style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0);">
            <children>
                <Label alignment="CENTER" layoutX="75.0" layoutY="50.0" prefWidth="300.0" text="Crie sua conta" textFill="#7e15d0">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>

                <TextField fx:id="txtEmail" layoutX="75.0" layoutY="130.0" prefHeight="35.0" prefWidth="300.0" promptText="exemplo@gmail.com" style="-fx-background-color: transparent; -fx-border-color: #7e15d0; -fx-border-width: 0 0 2px 0; -fx-font-size: 14px;" />
                <PasswordField fx:id="txtSenha" layoutX="75.0" layoutY="190.0" prefHeight="35.0" prefWidth="300.0" promptText="Senha" style="-fx-background-color: transparent; -fx-border-color: #7e15d0; -fx-border-width: 0 0 2px 0; -fx-font-size: 14px;" />

                <Label layoutX="75.0" layoutY="250.0" text="Selecione seu tipo de usuário:" textFill="#7e15d0">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <ListView fx:id="lvClientes" layoutX="75.0" layoutY="275.0" prefHeight="90.0" prefWidth="300.0" style="-fx-border-color: #7e15d0; -fx-border-radius: 5; -fx-background-radius: 5;" />

                <Label fx:id="lblErro" alignment="CENTER" layoutX="75.0" layoutY="380.0" prefWidth="300.0" style="-fx-text-fill: #d11a2a;" text="Preencha todos os campos!" visible="false">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <Button layoutX="75.0" layoutY="415.0" mnemonicParsing="false" onAction="#criarConta" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #7e15d0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Criar conta" />
                <Button layoutX="235.0" layoutY="415.0" mnemonicParsing="false" onAction="#voltarLogin" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: transparent; -fx-border-color: #7e15d0; -fx-border-radius: 20; -fx-text-fill: #7e15d0; -fx-font-weight: bold; -fx-cursor: hand;" text="Voltar para login" />
            </children>
        </Pane>

    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Cinema.Controller.ControllerLogin">
   <children>
      <Label layoutX="411.0" layoutY="192.0" text="Faça seu Login" />

      <TextField fx:id="txtEmail" layoutX="375.0" layoutY="228.0" promptText="Email" />

      <PasswordField fx:id="txtSenha" layoutX="375.0" layoutY="270.0" promptText="Senha" />

      <Button layoutX="426.0" layoutY="311.0" onAction="#fazerLogin" text="Entrar" />

      <Label fx:id="lblErro" layoutX="100" layoutY="210" style="-fx-text-fill: red;" text="Email ou senha inválidos" visible="false" />
      <Label layoutX="374.0" layoutY="152.0" text="Bem vindo ao CineStar Plaza" />

   </children>

</AnchorPane>

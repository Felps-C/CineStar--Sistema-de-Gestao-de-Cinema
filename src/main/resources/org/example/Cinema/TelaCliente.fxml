<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Cinema.Controller.ControllerTelaCliente">

        <children>

            <ListView fx:id="lvFilmes" layoutX="206.0" layoutY="29.0" prefHeight="150" prefWidth="180" />

            <Label fx:id="lblInfo" layoutX="410.0" layoutY="20.0" wrapText="true" />

            <ComboBox fx:id="cbSessoes" layoutX="411.0" layoutY="187.0" promptText="Sessão" />

            <Spinner fx:id="spQuantidade" layoutX="411.0" layoutY="224.0" />

            <Label fx:id="lblTotal" layoutX="411.0" layoutY="259.0" text="Total: R$ 0,00" />

            <Button layoutX="411.0" layoutY="283.0" onAction="#comprar" text="Comprar" />

            <Label fx:id="lblMensagem" layoutX="410.0" layoutY="320.0" visible="false" />
      <Button fx:id="Voltar" layoutX="30.0" layoutY="25.0" mnemonicParsing="false" onAction="#VoltarLogin" text="Login" />

        </children>
    </AnchorPane>
